{% extends 'base.html.twig' %}

{% block title %}Nouveau résultat biologique - {{ patient.fullName }}{% endblock %}

{% block body %}
<div class="patient-page">
    {% include 'patient/_medical_nav.html.twig' %}

    <div class="section-header">
        <h2>Ajouter un résultat biologique</h2>
    </div>

    <div class="form-container">
        {{ form_start(form) }}
            <div class="form-group">
                {{ form_row(form.date) }}
            </div>

            <fieldset class="form-fieldset">
                <legend>Fonction rénale</legend>
                <div class="form-grid form-grid-3">
                    <div class="form-group">
                        {{ form_row(form.creatinine) }}
                    </div>
                    <div class="form-group">
                        {{ form_row(form.creatinineClearance) }}
                    </div>
                    <div class="form-group">
                        {{ form_row(form.proteinuria) }}
                    </div>
                </div>
            </fieldset>

            <fieldset class="form-fieldset">
                <legend>Hématologie</legend>
                <div class="form-grid form-grid-3">
                    <div class="form-group">
                        {{ form_row(form.hemoglobin) }}
                    </div>
                    <div class="form-group">
                        {{ form_row(form.whiteBloodCells) }}
                    </div>
                    <div class="form-group">
                        {{ form_row(form.platelets) }}
                    </div>
                </div>
            </fieldset>

            <fieldset class="form-fieldset">
                <legend>Immunosuppresseurs</legend>
                <div class="form-grid">
                    <div class="form-group">
                        {{ form_row(form.tacrolimusLevel) }}
                    </div>
                    <div class="form-group">
                        {{ form_row(form.ciclosporinLevel) }}
                    </div>
                </div>
            </fieldset>

            <fieldset class="form-fieldset">
                <legend>Virologie</legend>
                <div class="form-grid">
                    <div class="form-group">
                        {{ form_row(form.cmvPcr) }}
                    </div>
                    <div class="form-group">
                        {{ form_row(form.ebvPcr) }}
                    </div>
                </div>
            </fieldset>

            <div class="form-group">
                {{ form_row(form.comment) }}
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Enregistrer</button>
                <a href="{{ path('app_biological_result_index', {patientId: patient.id}) }}" class="btn btn-secondary">Annuler</a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
