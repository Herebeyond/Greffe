{% extends 'base.html.twig' %}

{% block title %}Consultations - {{ patient.fullName }}{% endblock %}

{% block body %}
<div class="patient-page">
    {% include 'patient/_medical_nav.html.twig' %}

    <div class="section-header">
        <h2>Consultations</h2>
        {% if is_granted('CAN_WRITE') %}
        <a href="{{ path('app_consultation_new', {patientId: patient.id}) }}" class="btn btn-primary">Ajouter une consultation</a>
        {% endif %}
    </div>

    {% if consultations is empty %}
        <div class="empty-state">
            <p>Aucune consultation enregistrée pour ce patient.</p>
        </div>
    {% else %}
        <div class="data-table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Praticien</th>
                        <th>Observations</th>
                        <th>Prochain RDV</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for consultation in consultations %}
                    <tr>
                        <td>{{ consultation.date|date('d/m/Y') }}</td>
                        <td><span class="badge">{{ consultation.type }}</span></td>
                        <td>{{ consultation.practitionerName }}</td>
                        <td>{{ consultation.observations }}</td>
                        <td>{{ consultation.nextAppointmentDate ? consultation.nextAppointmentDate|date('d/m/Y') : '—' }}</td>
                        <td class="actions-cell">
                            {% if is_granted('CAN_WRITE') %}
                            <a href="{{ path('app_consultation_edit', {patientId: patient.id, id: consultation.id}) }}" class="btn-small">Modifier</a>
                            {% endif %}
                            {% if is_granted('CAN_DELETE') %}
                            <form action="{{ path('app_consultation_delete', {patientId: patient.id, id: consultation.id}) }}" method="post" class="inline-form"
                                  onsubmit="return confirm('Supprimer cette consultation ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ consultation.id) }}">
                                <button type="submit" class="btn-small btn-small-danger">Supprimer</button>
                            </form>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}
