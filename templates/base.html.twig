<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Gestion des Greffes Rénales{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🫘</text></svg>">
        <link rel="stylesheet" href="/css/style.css">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
        {% endblock %}
    </head>
    <body>
        <header>
            <div class="header-container">
                <a href="{{ path('app_home') }}" class="header-logo">
                    Greffes Rénales
                </a>

                {% if app.user %}
                <nav class="header-nav">
                    {% if is_granted('ROLE_TECH_ADMIN') %}
                    <a href="{{ path('app_admin_users') }}" class="header-link header-admin">Administration</a>
                    {% endif %}
                    <span class="header-user">{{ app.user.fullName }}</span>
                    <a href="{{ path('app_logout') }}" class="header-link">Déconnexion</a>
                </nav>
                {% endif %}
            </div>
            {% block header %}{% endblock %}
        </header>

        <main>
            {% block body %}{% endblock %}
        </main>
    </body>
</html>
