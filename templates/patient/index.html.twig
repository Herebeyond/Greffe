{% extends 'base.html.twig' %}

{% block title %}Patients - Gestion des Greffes Rénales{% endblock %}

{% block body %}
<div class="patient-page">
    <div class="page-header">
        <h1>Gestion des Patients</h1>
        {% if is_granted('CAN_WRITE') %}
        <a href="{{ path('app_patient_new') }}" class="btn btn-primary">Nouveau Patient</a>
        {% endif %}
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-error">{{ message }}</div>
    {% endfor %}

    <div class="search-section">
        <h2>Rechercher un patient</h2>
        <p class="search-hint">Renseignez au moins un critère de recherche</p>
        
        <form method="post" action="{{ path('app_patient_index') }}" class="search-form">
            <input type="hidden" name="_token" value="{{ csrf_token('patient_search') }}">
            <div class="search-grid">
                <div class="form-group">
                    <label for="lastName">Nom</label>
                    <input type="text" id="lastName" name="lastName" value="{{ criteria.lastName }}" placeholder="Ex: Dupont">
                </div>
                
                <div class="form-group">
                    <label for="firstName">Prénom</label>
                    <input type="text" id="firstName" name="firstName" value="{{ criteria.firstName }}" placeholder="Ex: Jean">
                </div>
                
                <div class="form-group">
                    <label for="fileNumber">Numéro de dossier</label>
                    <input type="text" id="fileNumber" name="fileNumber" value="{{ criteria.fileNumber }}" placeholder="Ex: 2023-001234">
                </div>
                
                <div class="form-group">
                    <label for="city">Ville de résidence</label>
                    <input type="text" id="city" name="city" value="{{ criteria.city }}" placeholder="Ex: Paris">
                </div>

            </div>
            
            <div class="search-actions">
                <button type="submit" class="btn btn-primary">Rechercher</button>
                <a href="{{ path('app_patient_index') }}" class="btn btn-secondary">Réinitialiser</a>
            </div>
        </form>
    </div>

    {% if showConfirmation %}
        <div class="confirmation-dialog">
            <div class="confirmation-content">
                <h3>Attention</h3>
                <p>Votre recherche a retourné <strong>{{ total }}</strong> résultats.</p>
                <p>Voulez-vous afficher tous ces résultats ?</p>
                <div class="confirmation-actions">
                    <form method="post" action="{{ path('app_patient_index') }}" class="inline-form">
                        <input type="hidden" name="_token" value="{{ csrf_token('patient_search') }}">
                        <input type="hidden" name="lastName" value="{{ criteria.lastName }}">
                        <input type="hidden" name="firstName" value="{{ criteria.firstName }}">
                        <input type="hidden" name="fileNumber" value="{{ criteria.fileNumber }}">
                        <input type="hidden" name="city" value="{{ criteria.city }}">
                        <input type="hidden" name="confirmed" value="1">
                        <button type="submit" class="btn btn-primary">Oui, afficher</button>
                    </form>
                    <a href="{{ path('app_patient_index') }}" class="btn btn-secondary">Non, modifier la recherche</a>
                </div>
            </div>
        </div>
    {% elseif patients|length > 0 %}
        <div class="results-section">
            <div class="results-header">
                <h2>{% if hasSearchCriteria %}Résultats{% else %}Mes patients{% endif %}</h2>
                <span class="results-count">{{ total }} patient(s){% if hasSearchCriteria %} trouvé(s){% endif %}</span>
            </div>

            <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nom</th>
                            <th>Prénom</th>
                            <th>N° Dossier</th>
                            <th>Ville</th>
                            <th>Sexe</th>
                            <th>Groupe sanguin</th>
                            <th class="actions-column">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for patient in patients %}
                        {% set activeBtg = btgAccesses[patient.id] ?? null %}
                        <tr{% if activeBtg %} class="btg-active-row"{% endif %}>
                            <td>{{ patient.id }}</td>
                            <td>{{ patient.lastName }}</td>
                            <td>{{ patient.firstName }}</td>
                            <td>{{ patient.fileNumber }}</td>
                            <td>{{ patient.city }}</td>
                            <td>{{ patient.sexLabel ?? '-' }}</td>
                            <td>{{ patient.fullBloodGroup ?? '-' }}</td>
                            <td class="actions-cell">
                                {% if is_granted('VIEW_PATIENT', patient) %}
                                <a href="{{ path('app_patient_show', {id: patient.id}) }}" class="btn btn-small">Voir</a>
                                    {% if is_granted('CAN_WRITE') %}
                                <a href="{{ path('app_patient_edit', {id: patient.id}) }}" class="btn btn-small btn-secondary">Modifier</a>
                                    {% endif %}
                                    {% if activeBtg %}
                                <span class="btg-badge" data-expires="{{ activeBtg.expiresAt|date('c') }}">⚠️ Bris de glace — <span class="btg-countdown"></span></span>
                                    {% endif %}
                                {% else %}
                                <span class="text-restricted btg-trigger" data-patient-id="{{ patient.id }}" data-patient-name="{{ patient.lastName }} {{ patient.firstName }}" data-patient-file="{{ patient.fileNumber }}">Accès restreint</span>
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>

                {% if totalPages > 1 %}
                <nav class="pagination">
                    {% if page > 1 %}
                        <form method="post" action="{{ path('app_patient_index') }}" class="inline-form">
                            <input type="hidden" name="_token" value="{{ csrf_token('patient_search') }}">
                            <input type="hidden" name="lastName" value="{{ criteria.lastName }}">
                            <input type="hidden" name="firstName" value="{{ criteria.firstName }}">
                            <input type="hidden" name="fileNumber" value="{{ criteria.fileNumber }}">
                            <input type="hidden" name="city" value="{{ criteria.city }}">
                            <input type="hidden" name="confirmed" value="1">
                            <input type="hidden" name="page" value="{{ page - 1 }}">
                            <button type="submit" class="pagination-link">&laquo; Précédent</button>
                        </form>
                    {% endif %}
                    
                    <span class="pagination-info">Page {{ page }} sur {{ totalPages }}</span>
                    
                    {% if page < totalPages %}
                        <form method="post" action="{{ path('app_patient_index') }}" class="inline-form">
                            <input type="hidden" name="_token" value="{{ csrf_token('patient_search') }}">
                            <input type="hidden" name="lastName" value="{{ criteria.lastName }}">
                            <input type="hidden" name="firstName" value="{{ criteria.firstName }}">
                            <input type="hidden" name="fileNumber" value="{{ criteria.fileNumber }}">
                            <input type="hidden" name="city" value="{{ criteria.city }}">
                            <input type="hidden" name="confirmed" value="1">
                            <input type="hidden" name="page" value="{{ page + 1 }}">
                            <button type="submit" class="pagination-link">Suivant &raquo;</button>
                        </form>
                    {% endif %}
                </nav>
                {% endif %}
        </div>
    {% else %}
        <div class="search-prompt">
            {% if hasSearchCriteria %}
                <p>Aucun patient trouvé pour ces critères de recherche.</p>
            {% else %}
                <p>Aucun patient ne vous est assigné. Utilisez le formulaire ci-dessus pour rechercher des patients.</p>
            {% endif %}
        </div>
    {% endif %}
</div>

<div id="btg-modal" class="btg-modal-overlay">
    <div class="btg-modal-content">
        <button type="button" class="btg-modal-close" aria-label="Fermer">&times;</button>
        <h2>⚠️ Accès d'urgence (Bris de glace)</h2>
        <div class="alert alert-warning">
            <strong>Attention :</strong> Cette procédure est réservée aux situations d'urgence médicale.
            Tout accès sera journalisé et audité.
        </div>
        <div class="btg-patient-info">Patient : <span id="btg-patient-info"></span></div>
        <ul class="btg-conditions">
            <li>Cet accès est limité à 3 heures</li>
            <li>Une justification détaillée est obligatoire</li>
            <li>Un audit sera effectué par les responsables médicaux</li>
        </ul>
        <form class="btg-form" method="post" action="">
            <input type="hidden" name="break_the_glass[_token]" value="{{ csrf_token('break_the_glass') }}">
            <label for="btg-justification"><strong>Justification de l'accès d'urgence</strong></label>
            <textarea id="btg-justification" name="break_the_glass[justification]" rows="4"
                      placeholder="Décrivez la raison de cet accès exceptionnel (ex: patient inconscient aux urgences, prise en charge urgente...)"
                      required minlength="10"></textarea>
            <div id="btg-error" class="btg-error" style="display:none"></div>
            <div class="btg-actions">
                <button type="button" class="btn btn-secondary btg-cancel">Annuler</button>
                <button type="submit" class="btn btn-danger">Confirmer l'accès d'urgence</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // BTG Modal
    var modal = document.getElementById('btg-modal');
    if (modal) {
        var closeBtn = modal.querySelector('.btg-modal-close');
        var cancelBtn = modal.querySelector('.btg-cancel');
        var form = modal.querySelector('.btg-form');
        var patientInfo = document.getElementById('btg-patient-info');
        var justificationInput = document.getElementById('btg-justification');
        var errorEl = document.getElementById('btg-error');

        document.querySelectorAll('.btg-trigger').forEach(function(el) {
            el.addEventListener('click', function() {
                var patientId = this.dataset.patientId;
                var patientName = this.dataset.patientName;
                var patientFile = this.dataset.patientFile;
                patientInfo.textContent = patientFile + ' — ' + patientName;
                justificationInput.value = '';
                errorEl.style.display = 'none';
                form.action = '/break-the-glass/' + encodeURIComponent(patientId);
                modal.classList.add('btg-modal-visible');
                justificationInput.focus();
            });
        });

        function closeModal() {
            modal.classList.remove('btg-modal-visible');
        }

        closeBtn.addEventListener('click', closeModal);
        cancelBtn.addEventListener('click', closeModal);

        modal.addEventListener('click', function(e) {
            if (e.target === modal) closeModal();
        });

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeModal();
        });

        form.addEventListener('submit', function(e) {
            var val = justificationInput.value.trim();
            if (val.length < 10) {
                e.preventDefault();
                errorEl.textContent = 'La justification doit contenir au moins 10 caractères.';
                errorEl.style.display = 'block';
                justificationInput.focus();
            }
        });
    }

    // BTG Countdown timers
    function updateCountdowns() {
        document.querySelectorAll('.btg-badge').forEach(function(badge) {
            var expiresAt = new Date(badge.dataset.expires);
            var now = new Date();
            var diff = expiresAt - now;
            var countdown = badge.querySelector('.btg-countdown');

            if (diff <= 0) {
                countdown.textContent = 'expiré';
                badge.classList.add('btg-expired');
                return;
            }

            var hours = Math.floor(diff / 3600000);
            var minutes = Math.floor((diff % 3600000) / 60000);
            var seconds = Math.floor((diff % 60000) / 1000);

            var parts = [];
            if (hours > 0) parts.push(hours + 'h');
            parts.push(minutes + 'min');
            parts.push(seconds + 's');
            countdown.textContent = parts.join(' ');
        });
    }

    updateCountdowns();
    setInterval(updateCountdowns, 1000);
});
</script>
{% endblock %}
