{% extends 'base.html.twig' %}

{% block title %}Mon Profil - Gestion des Greffes Rénales{% endblock %}

{% block body %}
<div class="admin-container">
    <div class="admin-header">
        <h1>Mon Profil</h1>
        <a href="{{ path('app_profile_change_password') }}" class="btn btn-primary">Changer le mot de passe</a>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <div class="profile-section">
        <h2>Informations personnelles</h2>
        <div class="profile-grid">
            <div class="profile-field">
                <span class="profile-label">Prénom</span>
                <span class="profile-value">{{ user.name }}</span>
            </div>
            <div class="profile-field">
                <span class="profile-label">Nom</span>
                <span class="profile-value">{{ user.surname }}</span>
            </div>
            <div class="profile-field">
                <span class="profile-label">Email</span>
                <span class="profile-value">{{ user.email }}</span>
            </div>
            <div class="profile-field">
                <span class="profile-label">Identifiant CRISTAL</span>
                <span class="profile-value">{{ user.cristalId ?? '—' }}</span>
            </div>
        </div>
    </div>

    <div class="profile-section">
        <h2>Rôles et accès</h2>
        <div class="profile-grid">
            <div class="profile-field">
                <span class="profile-label">Rôles</span>
                <span class="profile-value">
                    {% for role in user.roles %}
                        <span class="badge badge-{{ role|lower|replace({'role_': ''}) }}">
                            {% if role == 'ROLE_TECH_ADMIN' %}
                                Admin technique
                            {% elseif role == 'ROLE_MEDICAL_ADMIN' %}
                                Admin médical
                            {% elseif role == 'ROLE_DOCTOR' %}
                                Docteur
                            {% elseif role == 'ROLE_NURSE' %}
                                Infirmier(e)
                            {% elseif role == 'ROLE_PATIENT' %}
                                Patient
                            {% elseif role == 'ROLE_USER' %}
                                Utilisateur
                            {% else %}
                                {{ role|replace({'ROLE_': ''}) }}
                            {% endif %}
                        </span>
                    {% endfor %}
                </span>
            </div>
            <div class="profile-field">
                <span class="profile-label">Praticien CHU</span>
                <span class="profile-value">
                    {% if 'ROLE_TECH_ADMIN' in user.roles and 'ROLE_MEDICAL_ADMIN' not in user.roles %}
                        <span class="badge badge-secondary">N/A — administration technique uniquement</span>
                    {% elseif user.isChuPractitioner %}
                        <span class="badge badge-doctor">Oui — accès à tous les patients</span>
                    {% else %}
                        <span class="badge badge-user">Non — accès aux patients assignés uniquement</span>
                    {% endif %}
                </span>
            </div>
        </div>
    </div>

    <div class="profile-section">
        <h2>Sécurité</h2>
        <div class="profile-grid">
            <div class="profile-field">
                <span class="profile-label">Dernier changement de mot de passe</span>
                <span class="profile-value">
                    {{ lastPasswordChange ? lastPasswordChange|date('d/m/Y à H:i') : 'Jamais modifié' }}
                </span>
            </div>
            <div class="profile-field">
                <span class="profile-label">Dernière connexion</span>
                <span class="profile-value">
                    {{ user.lastLoginAt ? user.lastLoginAt|date('d/m/Y à H:i') : '—' }}
                </span>
            </div>
            <div class="profile-field">
                <span class="profile-label">Compte créé le</span>
                <span class="profile-value">{{ user.createdAt|date('d/m/Y') }}</span>
            </div>
        </div>
    </div>
</div>
{% endblock %}
