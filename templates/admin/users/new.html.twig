{% extends 'base.html.twig' %}

{% block title %}Ajouter un utilisateur{% endblock %}

{% block body %}
<div class="admin-container">
    <div class="admin-header">
        <h1>Ajouter un utilisateur</h1>
        <a href="{{ path('app_admin_users') }}" class="btn btn-secondary">Retour à la liste</a>
    </div>

    {{ form_start(form, {'attr': {'class': 'admin-form'}}) }}
        <div class="form-row">
            <div class="form-group">
                {{ form_label(form.name) }}
                {{ form_widget(form.name) }}
                {{ form_errors(form.name) }}
            </div>
            <div class="form-group">
                {{ form_label(form.surname) }}
                {{ form_widget(form.surname) }}
                {{ form_errors(form.surname) }}
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                {{ form_label(form.email) }}
                {{ form_widget(form.email) }}
                {{ form_errors(form.email) }}
            </div>
            <div class="form-group">
                {{ form_label(form.cristalId) }}
                {{ form_widget(form.cristalId) }}
                {{ form_errors(form.cristalId) }}
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                {{ form_label(form.plainPassword.first) }}
                {{ form_widget(form.plainPassword.first) }}
                {{ form_errors(form.plainPassword.first) }}
            </div>
            <div class="form-group">
                {{ form_label(form.plainPassword.second) }}
                {{ form_widget(form.plainPassword.second) }}
                {{ form_errors(form.plainPassword.second) }}
            </div>
        </div>

        <div class="form-group">
            {{ form_label(form.roles) }}
            <div class="checkbox-group">
                {{ form_widget(form.roles) }}
            </div>
            {{ form_errors(form.roles) }}
        </div>

        <div class="form-group">
            {{ form_label(form.isChuPractitioner) }}
            {{ form_widget(form.isChuPractitioner) }}
            {{ form_errors(form.isChuPractitioner) }}
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Créer l'utilisateur</button>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}
