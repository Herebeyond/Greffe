{% extends 'base.html.twig' %}

{% block title %}Administration - Journal d'audit{% endblock %}

{% block body %}
<div class="admin-container audit-container">
    <div class="admin-header">
        <h1>Journal d'audit</h1>
        <a href="{{ path('app_admin_users') }}" class="btn btn-secondary">Gestion des utilisateurs</a>
    </div>

    {% for message in app.flashes('error') %}
        <div class="alert alert-error">{{ message }}</div>
    {% endfor %}

    <div class="search-section">
        <h2>Filtres</h2>
        <form method="post" action="{{ path('app_admin_audit_logs') }}" class="search-form">
            <input type="hidden" name="_token" value="{{ csrf_token('audit_log_filter') }}">
            <div class="search-grid">
                <div class="form-group">
                    <label for="user">Utilisateur</label>
                    <input type="text" id="user" name="user" value="{{ filters.user }}" placeholder="Email ou identifiant">
                </div>
                <div class="form-group">
                    <label for="action">Action</label>
                    <select id="action" name="action">
                        <option value="">Toutes</option>
                        {% for value, label in actions %}
                            <option value="{{ value }}" {{ filters.action == value ? 'selected' }}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="form-group">
                    <label for="entityType">Type d'entité</label>
                    <select id="entityType" name="entityType">
                        <option value="">Tous</option>
                        {% for type in entityTypes %}
                            <option value="{{ type }}" {{ filters.entityType == type ? 'selected' }}>{{ type }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="form-group">
                    <label for="dateFrom">Date début</label>
                    <input type="datetime-local" id="dateFrom" name="dateFrom" value="{{ filters.dateFrom }}">
                </div>
                <div class="form-group">
                    <label for="dateTo">Date fin</label>
                    <input type="datetime-local" id="dateTo" name="dateTo" value="{{ filters.dateTo }}">
                </div>
            </div>
            <div class="search-actions">
                <button type="submit" class="btn btn-primary">Filtrer</button>
                <a href="{{ path('app_admin_audit_logs') }}" class="btn btn-secondary">Réinitialiser</a>
            </div>
        </form>
    </div>

    <div class="results-section">
        <div class="results-header">
            <h2>Résultats</h2>
            <span class="results-count" id="audit-count">{{ totalLogs }} entrée{{ totalLogs > 1 ? 's' }}</span>
        </div>

        <table class="data-table audit-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Utilisateur</th>
                    <th>Action</th>
                    <th>Entité</th>
                    <th>ID</th>
                    <th>Méthode</th>
                    <th>URI</th>
                    <th>IP</th>
                    <th>Détails</th>
                </tr>
            </thead>
            <tbody id="audit-tbody">
                {% for log in logs %}
                <tr class="audit-row-{{ log.action }}">
                    <td class="audit-date">{{ log.createdAt|date('d/m/Y H:i:s') }}</td>
                    <td class="audit-user">
                        {% if log.user %}
                            {{ log.user.fullName }}<br>
                            <span class="audit-user-email">({{ log.user.email }})</span>
                        {% else %}
                            {{ log.userIdentifier }}
                        {% endif %}
                    </td>
                    <td>
                        <span class="audit-badge audit-badge-{{ log.action }}">{{ log.actionLabel }}</span>
                    </td>
                    <td>{{ log.entityType ?? '-' }}</td>
                    <td>{{ log.entityId ?? '-' }}</td>
                    <td><span class="http-method http-{{ log.httpMethod|lower }}">{{ log.httpMethod }}</span></td>
                    <td class="audit-uri" title="{{ log.uri }}">{{ log.uri }}</td>
                    <td>{{ log.ipAddress ?? '-' }}</td>
                    <td class="audit-details" title="{{ log.details }}">{{ log.details ?? '-' }}</td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="9" class="no-results">Aucune entrée trouvée</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>

        <div id="audit-loader" class="audit-loader" {% if not hasMore %}style="display:none"{% endif %}>
            Chargement…
        </div>
        <div id="audit-end" class="audit-end" {% if hasMore or totalLogs == 0 %}style="display:none"{% endif %}>
            Fin des résultats
        </div>
    </div>
</div>

<script>
(function() {
    var page = 1;
    var loading = false;
    var hasMore = {{ hasMore ? 'true' : 'false' }};
    var tbody = document.getElementById('audit-tbody');
    var loader = document.getElementById('audit-loader');
    var endMsg = document.getElementById('audit-end');
    var csrfToken = '{{ csrf_token('audit_log_more') }}';
    var url = '{{ path('app_admin_audit_logs_more') }}';

    var filters = {
        user: '{{ filters.user|default('')|e('js') }}',
        action: '{{ filters.action|default('')|e('js') }}',
        entityType: '{{ filters.entityType|default('')|e('js') }}',
        dateFrom: '{{ filters.dateFrom|default('')|e('js') }}',
        dateTo: '{{ filters.dateTo|default('')|e('js') }}'
    };

    function escapeHtml(str) {
        if (!str) return '-';
        var div = document.createElement('div');
        div.appendChild(document.createTextNode(str));
        return div.innerHTML;
    }

    function loadMore() {
        if (loading || !hasMore) return;
        loading = true;
        page++;
        loader.style.display = '';

        var formData = new FormData();
        formData.append('_token', csrfToken);
        formData.append('page', page);
        formData.append('user', filters.user);
        formData.append('action', filters.action);
        formData.append('entityType', filters.entityType);
        formData.append('dateFrom', filters.dateFrom);
        formData.append('dateTo', filters.dateTo);

        fetch(url, { method: 'POST', body: formData })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                data.rows.forEach(function(log) {
                    var tr = document.createElement('tr');
                    tr.className = 'audit-row-' + escapeHtml(log.action);
                    tr.innerHTML =
                        '<td class="audit-date">' + escapeHtml(log.createdAt) + '</td>' +
                        '<td class="audit-user">' + (log.userFullName ? escapeHtml(log.userFullName) + '<br><span class="audit-user-email">(' + escapeHtml(log.userEmail) + ')</span>' : escapeHtml(log.userIdentifier)) + '</td>' +
                        '<td><span class="audit-badge audit-badge-' + escapeHtml(log.action) + '">' + escapeHtml(log.actionLabel) + '</span></td>' +
                        '<td>' + escapeHtml(log.entityType) + '</td>' +
                        '<td>' + (log.entityId ?? '-') + '</td>' +
                        '<td><span class="http-method http-' + escapeHtml(log.httpMethod).toLowerCase() + '">' + escapeHtml(log.httpMethod) + '</span></td>' +
                        '<td class="audit-uri" title="' + escapeHtml(log.uri) + '">' + escapeHtml(log.uri) + '</td>' +
                        '<td>' + escapeHtml(log.ipAddress) + '</td>' +
                        '<td class="audit-details" title="' + escapeHtml(log.details) + '">' + escapeHtml(log.details) + '</td>';
                    tbody.appendChild(tr);
                });
                hasMore = data.hasMore;
                if (!hasMore) {
                    loader.style.display = 'none';
                    endMsg.style.display = '';
                }
                loading = false;
            })
            .catch(function() {
                loading = false;
                loader.style.display = 'none';
            });
    }

    // Infinite scroll: load more when user scrolls near bottom
    window.addEventListener('scroll', function() {
        if (!hasMore || loading) return;
        var scrollBottom = window.innerHeight + window.scrollY;
        var docHeight = document.documentElement.scrollHeight;
        if (scrollBottom >= docHeight - 300) {
            loadMore();
        }
    });
})();
</script>
{% endblock %}
