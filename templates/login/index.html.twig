{% extends 'base.html.twig' %}

{% block title %}Connexion - Gestion des Greffes Rénales{% endblock %}

{% block body %}
<div class="login-container">
    <div class="login-card">
        <h1>Connexion</h1>

        {% if error %}
            <div class="alert alert-error">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post">
            <div class="form-group">
                <label for="username">Email ou Identifiant CRISTAL</label>
                <input type="text" id="username" name="_username" value="{{ last_username }}" required autofocus placeholder="exemple@email.fr ou CRISTAL-123">
            </div>

            <div class="form-group">
                <label for="password">Mot de passe</label>
                <input type="password" id="password" name="_password" required placeholder="Votre mot de passe">
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="btn btn-primary">Se connecter</button>
        </form>

        <div class="form-footer">
            <p class="forgot-password-notice">Mot de passe oublié ? Contactez un administrateur :</p>
            {% if techAdminEmails is not empty %}
                <ul class="admin-email-list">
                    {% for admin in techAdminEmails %}
                        <li><a href="mailto:{{ admin.email }}">{{ admin.name }} ({{ admin.email }})</a></li>
                    {% endfor %}
                </ul>
            {% else %}
                <p class="admin-email-fallback">Aucun administrateur disponible. Veuillez contacter le service informatique.</p>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
